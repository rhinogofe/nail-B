# PostgreSQL (local)
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/nail_booking

# หรือแยกค่าแทน DATABASE_URL
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_NAME=nail_booking

# Render production (ตัวอย่าง)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# DATABASE_SSL=true

JWT_SECRET=change_this_to_something_long_and_random
JWT_EXPIRES_IN=7d

PORT=3000
# คั่นหลาย origin ด้วย comma (local + Netlify)
FRONTEND_URL=http://localhost:5173,https://resilient-parfait-eee280.netlify.app

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

LINE_CLIENT_ID=
LINE_CLIENT_SECRET=
LINE_CALLBACK_URL=http://localhost:3000/api/auth/line/callback

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback
